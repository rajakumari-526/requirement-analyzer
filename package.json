{
  "name": "requirement-analyzer",
  "displayName": "Requirement Analyzer",
  "description": "AI-powered Requirement Analyzer for QA Engineers using Ollama",
  "version": "1.0.0",
  "publisher": "rajakumari",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Testing",
    "Programming Languages"
  ],
  "keywords": [
    "qa",
    "testing",
    "requirements",
    "ai",
    "ollama",
    "playwright",
    "automation"
  ],
  "activationEvents": [
    "onCommand:requirementAnalyzer.analyze"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "requirementAnalyzer.analyze",
        "title": "Requirement Analyzer: Analyze Requirement"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rajakumari/requirement-analyzer.git"
  },
  "license": "MIT"
  
}